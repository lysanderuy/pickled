# Supabase project (Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Postgres connections (Dashboard -> Connect)
# DATABASE_URL: app runtime. "Transaction" pooler (port 6543) — serverless-safe.
# DIRECT_URL: drizzle-kit migrations only. "Session" pooler (port 5432) —
# transaction mode breaks migrations (no prepared statement support).
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Resend (transactional email — https://resend.com/api-keys)
# Sender domain must be verified in Resend (SPF + DKIM DNS records).
# Also sends confirm-signup and password-recovery email, via /api/auth/email-hook,
# wired up in production as Supabase's Send Email Hook:
#   Supabase Dashboard -> Authentication -> Hooks -> Send Email Hook
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Acme <hello@mail.yourdomain.com>

# Signing secret for the Send Email Hook above (Dashboard -> Authentication ->
# Hooks), format "v1,whsec_...". Gates /api/auth/email-hook.
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_webhook_secret

# Upstash Redis (rate limiting — https://console.upstash.com, REST API tab).
# Optional: without these, src/lib/rate-limit.ts no-ops and requests pass
# through unthrottled.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
